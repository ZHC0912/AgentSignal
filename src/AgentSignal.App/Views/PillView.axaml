<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AgentSignal.App.Views"
             x:Class="AgentSignal.App.Views.PillView">

  <UserControl.Styles>
    <!-- Settings gear that sits at the edge of the expanded panel. -->
    <Style Selector="Button.gear">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="4" />
      <Setter Property="Margin" Value="6,-2,-4,0" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="Foreground" Value="#80FFFFFF" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe UI Symbol, Inter" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.gear:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.gear:pointerover">
      <Setter Property="Foreground" Value="#FFFFFFFF" />
    </Style>
  </UserControl.Styles>

  <Border CornerRadius="21"
          Background="#D90F1115"
          BorderBrush="#26FFFFFF"
          BorderThickness="1"
          Padding="15,10"
          HorizontalAlignment="Left"
          VerticalAlignment="Top">
    <Panel>
      <!-- Collapsed: the single aggregate light (most-urgent colour + driving session's timer). -->
      <views:DotsView DataContext="{Binding}" IsVisible="{Binding !IsExpanded}" />

      <!-- Expanded: one row per live session (dots + timer each) plus a settings gear at the edge. -->
      <Grid IsVisible="{Binding IsExpanded}" ColumnDefinitions="*,Auto">
        <ItemsControl Grid.Column="0" ItemsSource="{Binding Sessions}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Vertical" Spacing="11" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <views:DotsView />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Grid.Column="1" Classes="gear" Content="&#x2699;"
                ToolTip.Tip="Settings" Click="OnGearClick" />
      </Grid>
    </Panel>
  </Border>
</UserControl>
