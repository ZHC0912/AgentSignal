<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AgentSignal.App.Views.ToastWindow"
        Title="AgentSignal"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Focusable="False"
        CanResize="False"
        SizeToContent="WidthAndHeight">
  <Border CornerRadius="11"
          Background="#F21B1D23"
          BorderBrush="#33FFFFFF"
          BorderThickness="1"
          Padding="16,13"
          Margin="12">
    <StackPanel Spacing="3" MaxWidth="320">
      <TextBlock x:Name="TitleText" FontWeight="SemiBold" Foreground="White" FontSize="14" />
      <TextBlock x:Name="BodyText" Foreground="#CCFFFFFF" FontSize="13" TextWrapping="Wrap" />
    </StackPanel>
  </Border>
</Window>
